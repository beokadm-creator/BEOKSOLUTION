rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'aaron@beoksolution.com' || 
        request.auth.token.email == 'test@eregi.co.kr' ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Global Admin Access
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Society Rules
    match /societies/{societyId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /{allSubcollections=**} { 
         allow read: if true; 
         allow write: if isSuperAdmin(); 
      }
    }

    // Support Logging
    match /logs/{logId} {
      allow write: if true;
      allow read: if isSuperAdmin();
    }

    // Conferences
    match /conferences/{confId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Sponsors: Allow collection group queries
      match /sponsors/{sponsorId} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Registrations: Restricted read/write
      match /registrations/{userId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin() || 
                     (isAuthenticated() && request.resource.data.userId == request.auth.uid);
        
         match /logs/{logId} {
           allow read, write: if isOwner(userId); 
         }
      }

      // External Attendees: Admin only
      match /external_attendees/{attendeeId} {
        allow read, write: if isSuperAdmin();
      }

      // Stamps: Stamp Tour (인증된 사용자면 생성 가능)
      match /stamps/{stampId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isSuperAdmin();
      }
    }

    // Collection Group Query Rules
    match /{path=**}/sponsors/{sponsorId} {
      allow read: if true;
    }

    // User Profile
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();

      match /participations/{regId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isSuperAdmin(); // Usually created by function after payment
      }
    }
    
    // Global Collections
    match /booth_visits/{visitId} {
       allow read: if isAuthenticated() && (resource.data.vendorId == request.auth.uid || resource.data.vendorId == request.auth.token.vendorId);
       allow write: if isAuthenticated();
    }

    // Vendors (Partners/Sponsors)
    match /vendors/{vendorId} {
      // Helper: Check if user is authorized for this vendor
      // Uses get() to avoid undefined field issues
      function isVendorAdmin() {
        let vendorDoc = get(/databases/$(database)/documents/vendors/$(vendorId));
        return isSuperAdmin() ||
               (isAuthenticated() && vendorDoc.exists && 
                vendorDoc.data.adminEmail == request.auth.token.email);
      }

      // Vendor profile - only authorized admin can access
      allow read, write: if isVendorAdmin();

      // Subcollections - only authorized admin can access
      match /settings/{document=**} {
        allow read, write: if isVendorAdmin();
      }

      match /notification-templates/{templateId} {
        allow read, write: if isVendorAdmin();
      }

      // Leads contain PII - strict access control
      match /leads/{leadId} {
        allow read, create, update, delete: if isVendorAdmin();
      }
    }
  }
}

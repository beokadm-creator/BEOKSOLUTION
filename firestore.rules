rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'aaron@beoksolution.com' || 
        request.auth.token.email == 'test@eregi.co.kr' ||
        request.auth.token.admin == true
      );
    }

    function isSocietyAdmin(societyId) {
      let adminDoc = get(/databases/$(database)/documents/societies/$(societyId)/private/admin);
      return isAuthenticated() &&
        adminDoc.data != null &&
        adminDoc.data.adminEmails != null &&
        request.auth.token.email in adminDoc.data.adminEmails;
    }

    function isConferenceAdmin(confId) {
      let conf = get(/databases/$(database)/documents/conferences/$(confId)).data;
      return conf != null && isSocietyAdmin(conf.societyId);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function vendorDoc(vendorId) {
      return get(/databases/$(database)/documents/vendors/$(vendorId)).data;
    }

    function isVendorMember(vendorId) {
      return isAuthenticated() && (
        vendorDoc(vendorId).ownerUid == request.auth.uid ||
        vendorDoc(vendorId).adminEmail == request.auth.token.email ||
        (vendorDoc(vendorId).staffEmails != null && request.auth.token.email in vendorDoc(vendorId).staffEmails)
      );
    }

    // Global Admin Access
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Society Rules
    match /societies/{societyId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      // Public conference mapping under society namespace
      match /conferences/{confDocId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isSocietyAdmin(societyId);

        match /settings/{settingId} {
          allow read: if settingId in ['identity', 'visual', 'registration', 'ui'];
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }

        match /info/{docId} {
          allow read: if docId == 'general';
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }

        match /pages/{pageId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }

        match /agendas/{agendaId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }

        match /speakers/{speakerId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }

        match /sponsors/{sponsorId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isSocietyAdmin(societyId);
        }
      }

      // Public settings required by landing/registration flows
      match /settings/{settingId} {
        allow read: if settingId in ['identity', 'terms', 'infrastructure', 'membership-fees'];
        allow write: if isSuperAdmin();
      }

      // Public grade list used by registration pricing UI
      match /settings/grades/list/{gradeId} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Member directory contains personal data
      match /members/{memberId} {
        allow read: if isAuthenticated() || isSuperAdmin();
        allow write: if isSuperAdmin();
      }

      // Verification codes are sensitive
      match /verification_codes/{codeId} {
        allow read, write: if isSuperAdmin();
      }

      // Notification templates are admin resources
      match /notification-templates/{templateId} {
        allow read, write: if isSuperAdmin() || isSocietyAdmin(societyId);
      }

      // Private admin config (adminEmails) — PII protection
      match /private/admin {
        allow read: if isSuperAdmin() || isSocietyAdmin(societyId);
        allow write: if isSuperAdmin();
      }

      // Default deny for unlisted society subcollections
      match /{allSubcollections=**} {
         allow read, write: if isSuperAdmin();
      }
    }

    // Support Logging
    match /logs/{logId} {
      allow write: if isAuthenticated();
      allow read: if isSuperAdmin();
    }

    // Conferences
    match /conferences/{confId} {
      allow read: if true;
      allow write: if isSuperAdmin() || 
                   (resource != null && isSocietyAdmin(resource.data.societyId)) ||
                   (request.resource != null && isSocietyAdmin(request.resource.data.societyId));

      match /conference_options/{optionId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Public conference subcollections except explicitly restricted collections.
      // Restricted collections are handled by dedicated rules below.
      match /{subCollection}/{docPath=**} {
        allow read: if !(subCollection in [
          'certificates',
          'registrations',
          'external_attendees',
          'guestbook_entries',
          'notices',
          'vendor_requests',
          'stamp_tour_progress',
          'stamps',
          'badge_tokens',
          'users',
          'access_logs',
          'admins',
          'private_config',
          'notification_logs',
          'submissions',
          'whitelists',
          'vendors'
        ]);
        allow write: if isSuperAdmin();
      }

      match /notices/{noticeId} {
        allow get, list: if resource.data.status == 'PUBLISHED' || isSuperAdmin() || isConferenceAdmin(confId);
        allow write: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Sponsors: Allow collection group queries
      match /sponsors/{sponsorId} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Registrations: Restricted read/write
      match /registrations/{regId} {
        allow read: if isSuperAdmin() || isConferenceAdmin(confId) ||
          (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow write: if isSuperAdmin() || isConferenceAdmin(confId);
        
         match /logs/{logId} {
           allow read, write: if isSuperAdmin() || isConferenceAdmin(confId) ||
             (isAuthenticated() &&
              get(/databases/$(database)/documents/conferences/$(confId)/registrations/$(regId)).data.userId == request.auth.uid);
         }
      }

      // External Attendees: Admin only
      match /external_attendees/{attendeeId} {
        allow read, write: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Stamps: Stamp Tour
      match /stamps/{stampId} {
        allow read: if isSuperAdmin() || isOwner(resource.data.userId);
        allow create: if isSuperAdmin();
        allow update, delete: if isSuperAdmin();
      }

      // Stamp Tour Config
      match /settings/stamp_tour {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      match /settings/ui {
        allow read: if true;
        allow write: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Stamp Tour Progress
      match /stamp_tour_progress/{userId} {
        allow read: if isSuperAdmin() || isOwner(userId);
        allow create, update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // Guestbook entries: Require vendor consent flow
      match /guestbook_entries/{entryId} {
        allow read: if isSuperAdmin() || isVendorMember(resource.data.vendorId) || isOwner(resource.data.userId);
        allow create, update, delete: if isSuperAdmin();
      }

      // Submissions: owner can read own abstracts in MyPage
      match /submissions/{submissionId} {
        allow read: if isSuperAdmin() || isOwner(resource.data.userId);
        allow write: if isSuperAdmin();
      }

      // Moderator tokens: public read (token is unguessable document ID)
      match /moderator_tokens/{tokenId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Questions: moderator can toggle isAnswered without auth
      match /questions/{questionId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isSuperAdmin() || isConferenceAdmin(confId) ||
          // Allow unauthenticated moderator to toggle isAnswered only
          (isAuthenticated() &&
           request.resource.data.keys().hasOnly(['isAnswered']) &&
           request.resource.data.isAnswered is bool);
        allow delete: if isSuperAdmin() || isConferenceAdmin(confId);
      }

      // Vendor sponsorship requests
      match /vendor_requests/{requestId} {
        allow read: if isSuperAdmin() || isVendorMember(resource.data.vendorId) || isConferenceAdmin(confId);
        allow create, update: if isSuperAdmin() || isConferenceAdmin(confId) ||
          (isVendorMember(request.resource.data.vendorId) && request.resource.data.vendorId == requestId);
        allow delete: if isSuperAdmin() || isConferenceAdmin(confId);
      }
    }

    // Collection Group Query Rules
    match /{path=**}/vendor_requests/{requestId} {
      allow read: if isSuperAdmin() || isVendorMember(resource.data.vendorId);
    }
    match /{path=**}/sponsors/{sponsorId} {
      allow read: if true;
    }

    match /{path=**}/guestbook_entries/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/submissions/{submissionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User Profile
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();

      match /participations/{regId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isSuperAdmin(); // Usually created by function after payment
      }
    }
    
    // Global Collections
    match /booth_visits/{visitId} {
       allow read: if isAuthenticated() && (resource.data.vendorId == request.auth.uid || resource.data.vendorId == request.auth.token.vendorId);
       allow create: if isAuthenticated() &&
         (request.resource.data.vendorId == request.auth.uid || request.resource.data.vendorId == request.auth.token.vendorId);
       allow update, delete: if isSuperAdmin();
    }

    // Vendors (Partners/Sponsors)
    match /vendors/{vendorId} {
      // Vendor profile
      // - list: Allow authenticated users to query (for login page)
      // - get/write: Only authorized admin can access
      allow list: if isAuthenticated();
      allow get, write: if isSuperAdmin() || isVendorMember(vendorId);

      // Subcollections - check parent vendor document
      // Using get() to fetch parent document for authorization
      match /settings/{document=**} {
        allow read, write: if isSuperAdmin() || isVendorMember(vendorId);
      }

      match /notification-templates/{templateId} {
        allow read, write: if isSuperAdmin() || isVendorMember(vendorId);
      }

      // Leads contain PII - strict access control
      match /leads/{leadId} {
        allow read: if isSuperAdmin() || isVendorMember(vendorId);
        allow create, update, delete: if isSuperAdmin();
      }

      // Audit logs for vendor operations
      match /audit_logs/{logId} {
        allow read: if isSuperAdmin() || isVendorMember(vendorId);
        allow create: if (isSuperAdmin() || isVendorMember(vendorId)) &&
          request.resource.data.vendorId == vendorId;
        allow update, delete: if isSuperAdmin();
      }
    }

    // Global audit logs (Super Admin only)
    match /audit_logs/{logId} {
      allow read, write: if isSuperAdmin();
    }
  }
}

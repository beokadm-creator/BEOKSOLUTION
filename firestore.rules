rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'aaron@beoksolution.com' || 
        request.auth.token.email == 'test@eregi.co.kr' ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Global Admin Access
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Society Rules
    match /societies/{societyId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /{allSubcollections=**} { 
         allow read: if true; 
         allow write: if isSuperAdmin(); 
      }
    }

    // Support Logging
    match /logs/{logId} {
      allow write: if true;
      allow read: if isSuperAdmin();
    }

    // Conferences
    match /conferences/{confId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Registrations: Restricted read/write
      match /registrations/{userId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin() || 
                     (isAuthenticated() && request.resource.data.userId == request.auth.uid);
        
         match /logs/{logId} {
           allow read, write: if isOwner(userId); 
         }
      }

      // External Attendees: Admin only
      match /external_attendees/{attendeeId} {
        allow read, write: if isSuperAdmin();
      }

      // Stamps: Stamp Tour (인증된 사용자면 생성 가능)
      match /stamps/{stampId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isSuperAdmin();
      }
    }

    // User Profile
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();

      match /participations/{regId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isSuperAdmin(); // Usually created by function after payment
      }
    }
    
    // Global Collections
    match /booth_visits/{visitId} {
       allow read: if isAuthenticated() && (resource.data.vendorId == request.auth.uid || resource.data.vendorId == request.auth.token.vendorId);
       allow write: if isAuthenticated();
    }

    // Vendors (Partners/Sponsors)
    match /vendors/{vendorId} {
      // Helper function to check if user is authorized for this vendor
      // Uses resource.data for direct vendor document access
      function isVendorAuthorized() {
        return isSuperAdmin() ||
               isAuthenticated() && (
                 // Check if the vendor document has this user's email as adminEmail
                 request.auth.token.email == resource.data.adminEmail ||
                 request.auth.token.email in resource.data.staffEmails ||
                 // Also check by UID for owner
                 request.auth.uid == resource.data.ownerUid
               );
      }

      function isVendorAdmin() {
        return isSuperAdmin() ||
               isAuthenticated() && (
                 // Check if the vendor document has this user's email as adminEmail
                 request.auth.token.email == resource.data.adminEmail ||
                 // Also check by UID for owner
                 request.auth.uid == resource.data.ownerUid
               );
      }

      // Helper function for subcollections - fetches parent vendor document
      function getVendorData() {
        return get(/databases/$(database)/documents/vendors/$(vendorId));
      }

      function isVendorAuthorizedForSubcollection() {
        let vendorData = getVendorData();
        return isSuperAdmin() ||
               isAuthenticated() && (
                 request.auth.token.email == vendorData.data().adminEmail ||
                 request.auth.token.email in vendorData.data().staffEmails ||
                 request.auth.uid == vendorData.data().ownerUid
               );
      }

      function isVendorAdminForSubcollection() {
        let vendorData = getVendorData();
        return isSuperAdmin() ||
               isAuthenticated() && (
                 request.auth.token.email == vendorData.data().adminEmail ||
                 request.auth.uid == vendorData.data().ownerUid
               );
      }

      // Vendor profile access (uses resource.data directly)
      allow read: if isVendorAuthorized();
      allow write: if isVendorAdmin();

      // Vendor settings (infrastructure, notification configs)
      // Uses get() to fetch parent vendor document for authorization
      match /settings/{document=**} {
        allow read: if isVendorAuthorizedForSubcollection();
        allow write: if isVendorAdminForSubcollection();
      }

      // Vendor notification templates
      match /notification-templates/{templateId} {
        allow read: if isVendorAuthorizedForSubcollection();
        allow write: if isVendorAdminForSubcollection();
      }

      // Vendor leads (방문자 기록)
      match /leads/{leadId} {
        allow read: if isVendorAuthorizedForSubcollection();
        allow create: if isVendorAuthorizedForSubcollection();
        allow update, delete: if isVendorAdminForSubcollection();
      }
    }
  }
}

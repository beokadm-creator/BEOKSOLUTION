rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'aaron@beoksolution.com' || 
        request.auth.token.email == 'test@eregi.co.kr' ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // abstracts: User can manage their own, admin can see all
    match /conferences/{confId}/abstracts/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /conferences/{confId}/welcome/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /conferences/{confId}/assets/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /conferences/{confId}/notices/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /conferences/{confId}/speakers/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /conferences/{confId}/sponsors/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /societies/{societyId}/logo/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /societies/{societyId}/greeting/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /experts/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
